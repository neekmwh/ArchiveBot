# ==============================================================================
# Environment Configuration
# ==============================================================================
ENV=development                  # development, staging, production
PROJECT_NAME="Contractor CRM Backend"
DEBUG=true

# ==============================================================================
# Security & Authentication (JWT + HMAC)
# ==============================================================================
# Run "openssl rand -hex 32" to generate a secure secret key
SECRET_KEY=super_secret_jwt_signing_key_change_me_in_production_102030
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# ==============================================================================
# Telegram Bot Integration (Bot Auth & HMAC Validation)
# ==============================================================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ12345678
# HMAC Secret for validating pairing hashes
TELEGRAM_BOT_HMAC_SECRET=secure_telegram_bot_pairing_verification_secret_9988

# ==============================================================================
# Database Configuration (PostgreSQL 16 with RLS)
# ==============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_1020
POSTGRES_DB=contractor_crm
POSTGRES_PORT=5432
POSTGRES_HOST=db

# SQLAlchemy Connection String
# For docker environment: postgresql+psycopg2://postgres:postgres_password_1020@db:5432/contractor_crm
# For local environment: postgresql+psycopg2://postgres:postgres_password_1020@localhost:5432/contractor_crm
DATABASE_URL=postgresql+psycopg2://postgres:postgres_password_1020@db:5432/contractor_crm

# ==============================================================================
# Redis Cache & Rate Limiting
# ==============================================================================
# For docker environment: redis://redis:6379/0
# For local environment: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ==============================================================================
# S3-Compatible Storage (MinIO or AWS S3)
# ==============================================================================
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_REGION=us-east-1

S3_MAIN_BUCKET=contractor-crm-storage
S3_QUARANTINE_BUCKET=contractor-crm-quarantine

# ==============================================================================
# ClamAV Antivirus Daemon
# ==============================================================================
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ==============================================================================
# Audit Log Cryptographic Chaining
# ==============================================================================
# Cryptographic salt used in generating record SHA-256 hashes for the blockchain
AUDIT_LOG_SALT=cryptographic_audit_chain_block_salt_key_0102
